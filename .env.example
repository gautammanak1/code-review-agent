# --- ASI:One LLM (https://docs.asi1.ai) ---
# Used by the LangChain agent (langchain-openai's ChatOpenAI is pointed at
# https://api.asi1.ai/v1 inside ai/ai.py, so any OpenAI-compatible key works).
# Get one from https://asi1.ai/dashboard/api-keys
ASI_ONE_API_KEY=sk_asi_xxx
# Optional override; defaults to "asi1"
ASI_ONE_MODEL=asi1

# --- GitHub ---
# Personal access token with `repo` scope (or fine-grained: pull-requests:write, issues:write).
# In GitHub Actions this is provided automatically as ${{ secrets.GITHUB_TOKEN }}.
GITHUB_TOKEN=ghp_xxx

# --- Behavior ---
# When "true", the agent generates a review but does NOT post comments to GitHub.
DRY_RUN=false
